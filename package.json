{
  "name": "accessibility-auditor-scaffold",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check:precommit": "npm run format:code && npm run check:all",
    "check:all": "npm run check:lint && npm run check:types",
    "check:lint": "eslint --fix --report-unused-disable-directives .",
    "check:types": "tsc --noEmit --extendedDiagnostics",
    "format:code": "prettier --write .",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:studio": "open http://127.0.0.1:54323",
    "db:migration:new": "supabase migration new",
    "db:types": "supabase gen types typescript --local > src/types/database.types.ts"
  },
  "dependencies": {
    "@axe-core/puppeteer": "^4.11.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/material-nextjs": "^7.3.9",
    "@reduxjs/toolkit": "^2.11.2",
    "@sparticuz/chromium": "^143.0.4",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "@tanstack/react-table": "^8.21.3",
    "next": "16.1.6",
    "puppeteer-core": "^24.39.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-redux": "^9.2.0",
    "react-use": "^17.6.0",
    "recharts": "^3.8.0",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-baseline-js": "^0.6.1",
    "eslint-plugin-depend": "^1.5.0",
    "eslint-plugin-jsx-a11y-x": "^0.1.1",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.9.2",
    "eslint-plugin-sonarjs": "^4.0.2",
    "supabase": "^2.79.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
